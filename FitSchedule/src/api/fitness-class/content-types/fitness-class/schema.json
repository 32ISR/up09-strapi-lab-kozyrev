{
  "kind": "collectionType",
  "collectionName": "fitness_classes",
  "info": {
    "singularName": "fitness-class",
    "pluralName": "fitness-classes",
    "displayName": "FitnessClass"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "scheduledAt": {
      "type": "date"
    },
    "duration": {
      "type": "integer"
    },
    "maxCapacity": {
      "type": "integer"
    },
    "difficulty": {
      "type": "enumeration",
      "enum": [
        "easy",
        "moderate",
        "hard"
      ]
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "yoga",
        "cardio",
        "strength",
        "pilates",
        "hiit"
      ]
    },
    "room": {
      "type": "string"
    },
    "bookings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::booking.booking"
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag"
    }
  }
}
